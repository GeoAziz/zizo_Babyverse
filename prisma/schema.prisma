generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // For credentials provider
  role          Role      @default(PARENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  babies   Baby[]
  orders   Order[]
  wishlist WishlistItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  PARENT
}

model Baby {
  id        String   @id @default(cuid())
  name      String
  birthdate DateTime
  allergies String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String  @id @default(cuid())
  name          String
  description   String  @db.Text
  price         Float
  category      String
  imageUrl      String
  stock         Int
  tags          String[]
  ageGroup      String?
  ecoTag        Boolean @default(false)
  averageRating Float?
  features      String? // Comma-separated string or JSON
  targetAudience String?
  keywords      String?
  dataAiHint    String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  wishlistItems WishlistItem[]
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  totalAmount Float
  status    OrderStatus @default(PENDING)
  orderDate DateTime @default(now())
  
  shippingFullName String
  shippingAddress  String
  shippingCity     String
  shippingPostalCode String
  shippingCountry  String
  shippingEmail    String

  paymentMethod    String
  paymentStatus    String @default("PENDING") // e.g. PENDING, PAID, FAILED
  
  trackingNumber    String?
  estimatedDelivery DateTime?

  items     OrderItem[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String  // Denormalized product name at time of order
  quantity  Int
  price     Float   // Denormalized price at time of order

  @@unique([orderId, productId]) // Optional: ensure product appears once per order
}

enum OrderStatus {
  PENDING
  PROCESSING
  POD_PACKED // As per spec
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
}
