
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(PARENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  babies   Baby[]
  orders   Order[]
  wishlist WishlistItem[]
  cartItems CartItem[]
}

enum Role {
  ADMIN
  PARENT
}

model Baby {
  id        String   @id @default(cuid())
  name      String
  birthdate DateTime
  allergies String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id             String  @id @default(cuid())
  name           String
  description    String  @db.Text
  price          Float
  category       String
  imageUrl       String
  stock          Int
  tags           String[] @default([])
  ageGroup       String?
  ecoTag         Boolean @default(false)
  averageRating  Float?
  features       String? // Comma-separated or JSON string
  targetAudience String?
  keywords       String? // Comma-separated
  dataAiHint     String? // For Unsplash placeholder search hint

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems     OrderItem[]    @relation("ProductToOrderItems")
  wishlistItems  WishlistItem[]
  cartItems      CartItem[]
}

model Order {
  id                String   @id @default(cuid())
  totalAmount       Float
  status            String // e.g., Pending, Processing, Shipped, Delivered, Cancelled
  shippingAddress   Json // Store as JSON: { street: string, city: string, zip: string, country: string }
  paymentMethod     String
  trackingNumber    String?
  estimatedDelivery DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float  // Price of the product at the time of order
  name      String // Name of the product at the time of order

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  // Link to the original product, but allow it to be null if product is deleted
  product   Product? @relation("ProductToOrderItems", fields: [productId], references: [id], onDelete: SetNull)
  productId String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@unique([userId, productId])
}
