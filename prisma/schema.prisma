datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          Role            @default(PARENT)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  babies        Baby[]          // Relation to Baby model
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum Role {
  ADMIN
  PARENT
}

model Baby {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  birthdate         DateTime
  weightInKilograms Float? // Optional, can be added later
  allergies         String?  // Store as comma-separated string or JSON
  preferences       String?  // Store as comma-separated string or JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  name             String
  description      String?
  price            Float
  category         String
  imageUrl         String?
  stock            Int             @default(0)
  tags             String[]
  ageGroup         String? // e.g., "0-6 months", "1-2 years"
  ecoTag           Boolean?        @default(false)
  averageRating    Float?
  features         String? // Comma-separated or JSON string
  targetAudience   String?
  keywords         String? // Comma-separated for AI
  dataAiHint       String? // For placeholder image generation
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  orderItems       OrderItem[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  relatedProducts  Product[]       @relation("ProductRelated")
  relatedTo        Product[]       @relation("ProductRelated")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             OrderItem[]
  totalAmount       Float
  status            String      @default("Pending") // e.g., Pending, Processing, Pod Packed, Dispatched, In Transit, Delivered, Cancelled
  shippingAddress   Json // Store as JSON: { fullName, address, city, postalCode, country, email }
  paymentMethod     String?
  paymentIntentId   String?     @unique // For Stripe or other payment gateways
  trackingNumber    String?
  estimatedDelivery DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict) // Prevent product deletion if in an order
  name      String   // Store product name at time of order
  price     Float    // Store product price at time of order
  quantity  Int
  createdAt DateTime @default(now())
}

// For NextAuth.js
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Promotion {
  id           String    @id @default(cuid())
  code         String    @unique
  description  String?
  type         PromoType // PERCENTAGE or FIXED_AMOUNT
  value        Float     // Percentage value (e.g., 15 for 15%) or fixed amount
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean   @default(true)
  usageLimit   Int?      // Max number of times this promo can be used in total
  timesUsed    Int       @default(0)
  minSpend     Float?    // Minimum spend required to use this promo
  appliesTo    PromoTarget? // ALL_PRODUCTS, SPECIFIC_PRODUCTS, SPECIFIC_CATEGORIES
  productIds   String[]  // List of product IDs if appliesTo is SPECIFIC_PRODUCTS
  categoryNames String[] // List of category names if appliesTo is SPECIFIC_CATEGORIES
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromoTarget {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}
